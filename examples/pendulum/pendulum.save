QT       -= core
QT       -= gui
CONFIG   += console
CONFIG   -= app_bundle

TEMPLATE = app

# DEFINES += STR_UTIL_ENABLE_CUSTOM_UNICODE_OPERATIONS

INCLUDEPATH += ../../src \
    bullet3

HEADERS += bullet3/btBulletCollisionCommon.h \
    bullet3/btBulletDynamicsCommon.h

SOURCES += main.cpp \
    bullet3/btBulletCollisionAll.cpp \
    bullet3/btBulletDynamicsAll.cpp \
    bullet3/btLinearMathAll.cpp

QMAKE_CXXFLAGS += -std=c++23 -march=native
QMAKE_CXXFLAGS_RELEASE -= -O2
QMAKE_CXXFLAGS_RELEASE += -O3

LIBS += -lpthread -ldl
LIBS += -lraylib

SOURCES += main.cpp

