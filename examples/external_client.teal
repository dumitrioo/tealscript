extern 'tealscript://127.0.0.1:43987/just_a_regular_cell' value_from_net;

ext_value_use(vname, exv) {
    if(exv != this.exv) {
        this.exv = exv;
        console.print("remote ", typeof(exv), " \"", vname, "\": ", this.exv);
    }
    return 0;
}
ext_value_use use("value_from_net", value_from_net);
